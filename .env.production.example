# Production environment for docker-compose.prod.yml.
# Copy to .env.production and replace every __CHANGE_ME__ value. Do NOT commit .env.production.
#
# Generate a strong secret with:  openssl rand -base64 48

# ── Postgres ──
POSTGRES_USER=pdash
POSTGRES_PASSWORD=__CHANGE_ME__strong_db_password
POSTGRES_DB=pdash

# Prisma/API connection string. Inside compose the DB host is the "postgres" service name.
DATABASE_URL=postgresql://pdash:__CHANGE_ME__strong_db_password@postgres:5432/pdash?schema=public

# ── Auth ──
# 256-bit+ random value for signing access tokens. The API refuses to boot in production
# if this is unset, the placeholder default, or shorter than 32 chars.
JWT_ACCESS_SECRET=__CHANGE_ME__long_random_secret_min_32_chars

# ── Web origin ──
# The public origin(s) users browse to (comma-separated). Required in production.
CORS_ORIGINS=https://pdash.yourcompany.com

# Host port to publish the web app on (front it with TLS via a reverse proxy / load balancer).
WEB_PORT=3000
