# ── Dependencies ──────────────────────────────────────────
node_modules/
packages/db/node_modules/

# ── Build outputs ─────────────────────────────────────────
dist/
build/
.next/
out/
*.tsbuildinfo

# ── Logs ──────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Test coverage ─────────────────────────────────────────
coverage/

# ── Prisma generated client ───────────────────────────────
**/generated/

# ── Local dev database (PGlite fallback data) ─────────────
.pglite-data/

# ── AI / agent tooling artifacts (Claude, Cursor, Windsurf, MCP) ─
.claude/
.cursor/
.windsurf/
.playwright-mcp/

# ── Local debug screenshots at repo root (keep fav.png; keep committed assets under docs/) ─
/*.png
!fav.png

# ── Backup files (created during dev) ─────────────────────
*.bak

# ── Binary documents (source docs; committed reference PDFs live in docs/reference/) ─
*.docx
*.doc

# ── OS / editor ───────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
.cache/

# ── Secrets — NEVER commit real env or credential files ───
# (the *.example templates are safe placeholders and stay committed)
.env
.env.*
!.env.example
!.env.production.example
SquarkIP-credentials.*
kt-shots/
.data/
