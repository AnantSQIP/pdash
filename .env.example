# Copy to .env and adjust. Used by docker-compose, Prisma, and the API.

# --- Postgres ---
POSTGRES_USER=pdash
POSTGRES_PASSWORD=pdash
POSTGRES_DB=pdash
POSTGRES_PORT=5432

# Prisma / API connection string
DATABASE_URL=postgresql://pdash:pdash@localhost:5432/pdash?schema=public

# --- Redis (BullMQ, cache, websocket adapter) ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# --- MinIO (S3-compatible object storage) ---
MINIO_ROOT_USER=pdash
MINIO_ROOT_PASSWORD=pdash-secret
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- API ---
API_PORT=4000
NODE_ENV=development

# --- Auth ---
# JWT signing secret for short-lived access tokens. Generate a 256-bit random value in prod.
JWT_ACCESS_SECRET=change-me-to-a-long-random-secret
# Dev-only: trust x-actor-id header for curl/smoke tests (ignored when NODE_ENV=production).
AUTH_DEV_TRUST_HEADER=false
# Where the Next.js server proxies /api/* to (same-origin proxy keeps cookies first-party).
API_ORIGIN=http://localhost:4000
# Shared dev password for seeded users (local only).
SEED_DEFAULT_PASSWORD=sqip@1234
